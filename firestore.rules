rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isFamilyMember(familyId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/families/$(familyId)).data.memberUserIds.hasAny([request.auth.uid]);
    }

    function canManageFamily(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId)).data;
      return isSignedIn()
        && (
          family.leadAdultUserId == request.auth.uid
          || (family.coLeaderUserIds is list && family.coLeaderUserIds.hasAny([request.auth.uid]))
        );
    }

    function validReviewData(review) {
      return review.familyId is string
        && review.movieId is string
        && review.userId == request.auth.uid
        && review.parentScore is number
        && review.parentScore >= 1
        && review.parentScore <= 8
        && review.kidScore is number
        && review.kidScore >= 1
        && review.kidScore <= 8
        && review.pizzaScore is number
        && review.pizzaScore >= 1
        && review.pizzaScore <= 8
        && review.visibility in ["aggregate", "public"];
    }

    match /movies/{movieId} {
      allow read: if true;
      allow write: if false;
    }

    match /families/{familyId} {
      allow read: if isSignedIn() && resource.data.memberUserIds.hasAny([request.auth.uid]);
      allow create: if isSignedIn() && request.resource.data.leadAdultUserId == request.auth.uid;
      allow update, delete: if canManageFamily(familyId);
    }

    match /familyMembers/{memberId} {
      allow read: if isFamilyMember(resource.data.familyId);
      allow create: if canManageFamily(request.resource.data.familyId);
      allow update, delete: if canManageFamily(resource.data.familyId);
    }

    match /familyInvites/{inviteCode} {
      allow get: if true;
      allow list: if false;
      allow create: if canManageFamily(request.resource.data.familyId)
        && inviteCode == request.resource.data.code
        && request.resource.data.status == "active";
      allow update, delete: if canManageFamily(resource.data.familyId);
    }

    match /reviews/{reviewId} {
      allow read: if resource.data.visibility == "public" || isFamilyMember(resource.data.familyId);
      allow create: if canManageFamily(request.resource.data.familyId)
        && reviewId == request.resource.data.familyId + "_" + request.resource.data.movieId
        && validReviewData(request.resource.data);
      allow update: if canManageFamily(resource.data.familyId)
        && reviewId == resource.data.familyId + "_" + resource.data.movieId
        && request.resource.data.familyId == resource.data.familyId
        && request.resource.data.movieId == resource.data.movieId
        && validReviewData(request.resource.data);
      allow delete: if canManageFamily(resource.data.familyId);
    }

    match /aggregates/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
