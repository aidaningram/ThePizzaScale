rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isFamilyMember(familyId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/families/$(familyId)).data.memberUserIds.hasAny([request.auth.uid]);
    }

    function canManageFamily(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId)).data;
      return isSignedIn()
        && (
          family.leadAdultUserId == request.auth.uid
          || (family.coLeaderUserIds is list && family.coLeaderUserIds.hasAny([request.auth.uid]))
        );
    }

    function canDeleteFamily(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId)).data;
      return isSignedIn()
        && (
          family.createdByUserId == request.auth.uid
          || (family.createdByUserId == null && family.leadAdultUserId == request.auth.uid)
        );
    }

    function canRateFamily(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId)).data;
      return isSignedIn()
        && (
          family.leadAdultUserId == request.auth.uid
          || (family.coLeaderUserIds is list && family.coLeaderUserIds.hasAny([request.auth.uid]))
          || (family.ratingAdultUserIds is list && family.ratingAdultUserIds.hasAny([request.auth.uid]))
        );
    }

    function familyCodesArePermanent() {
      return (resource.data.inviteCode == null
          || request.resource.data.inviteCode == resource.data.inviteCode)
        && (resource.data.familyCode == null
          || request.resource.data.familyCode == resource.data.familyCode);
    }

    function validReviewData(review) {
      return review.familyId is string
        && review.movieId is string
        && review.userId == request.auth.uid
        && review.parentScore is number
        && review.parentScore >= 1
        && review.parentScore <= 8
        && review.kidScore is number
        && review.kidScore >= 1
        && review.kidScore <= 8
        && review.pizzaScore is number
        && review.pizzaScore >= 1
        && review.pizzaScore <= 8
        && review.visibility in ["aggregate", "public"]
        && review.familySnapshotAtReview is map;
    }

    match /movies/{movieId} {
      allow read: if true;
      allow write: if false;
    }

    match /movieGuides/{movieId} {
      allow read: if true;
      allow write: if false;
    }

    match /userProfiles/{userId} {
      allow read, create, update: if isSignedIn() && userId == request.auth.uid;
      allow delete: if false;
    }

    match /families/{familyId} {
      allow read: if isSignedIn() && resource.data.memberUserIds.hasAny([request.auth.uid]);
      allow create: if isSignedIn()
        && request.resource.data.leadAdultUserId == request.auth.uid
        && request.resource.data.createdByUserId == request.auth.uid;
      allow update: if canManageFamily(familyId) && familyCodesArePermanent();
      allow delete: if canDeleteFamily(familyId);
    }

    match /pizzaMovieNightFamilies/{familyId} {
      allow read, write: if isFamilyMember(familyId);
    }

    match /familyMembers/{memberId} {
      allow read: if isFamilyMember(resource.data.familyId);
      allow create: if canManageFamily(request.resource.data.familyId);
      allow update, delete: if canManageFamily(resource.data.familyId);
    }

    match /familyInvites/{inviteCode} {
      allow get: if true;
      allow list: if false;
      allow create: if canManageFamily(request.resource.data.familyId)
        && inviteCode == request.resource.data.code
        && request.resource.data.status == "active";
      allow update: if canManageFamily(resource.data.familyId)
        && request.resource.data.code == resource.data.code
        && request.resource.data.familyCode == resource.data.familyCode
        && request.resource.data.familyId == resource.data.familyId
        && request.resource.data.createdByUserId == resource.data.createdByUserId;
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if isFamilyMember(resource.data.familyId);
      allow create: if canRateFamily(request.resource.data.familyId)
        && reviewId == request.resource.data.familyId + "_" + request.resource.data.movieId
        && validReviewData(request.resource.data);
      allow update: if canRateFamily(resource.data.familyId)
        && reviewId == resource.data.familyId + "_" + resource.data.movieId
        && request.resource.data.familyId == resource.data.familyId
        && request.resource.data.movieId == resource.data.movieId
        && validReviewData(request.resource.data);
      allow delete: if canManageFamily(resource.data.familyId);
    }

    match /publicReviews/{reviewId} {
      allow read: if true;
      allow create: if canRateFamily(request.resource.data.familyId)
        && reviewId == request.resource.data.familyId + "_" + request.resource.data.movieId
        && request.resource.data.movieId is string
        && request.resource.data.familyName is string
        && request.resource.data.pizzaScore is number
        && request.resource.data.pizzaScore >= 1
        && request.resource.data.pizzaScore <= 8;
      allow update, delete: if canManageFamily(resource.data.familyId);
    }

    match /aggregates/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
